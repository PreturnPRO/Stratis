# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
build/
**/dist/

# Environment files — NEVER commit real values (dev/staging/prod all ignored)
.env
.env.*
**/.env
**/.env.*
# ...but keep the committed templates
!.env.example
!**/.env.example

# Database (local dev only)
data/
*.db
*.db-shm
*.db-wal

# IDE / local tooling (AI-assistant plugins, memories, and sidecars stay local)
.vscode/
.idea/
.claude/
**/.claude/
/.impeccable/
.playwright-mcp/
*.swp
*.swo

# Design scratch images at the repo root (mockup exports, drafts — local only;
# real assets belong in src/ or public/ and are unaffected)
/*.jpeg
/*.jpg
/*.png
/*.webp
/*.gif

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Working / closeout docs — new, local-only files (not tracked source):
# the docs/ folder (markdown + exported .pdf/.docx) and root working notes.
# Anchored paths so the tracked project docs (README.md, DESIGN.md, PRODUCT.md)
# and any *.md elsewhere are unaffected.
/CHANGES.md
/PRESENT-DATABASE.md
/docs/