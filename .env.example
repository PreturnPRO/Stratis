# Stratis environment template. Copy to .env and fill in.
#   cp .env.example .env
# Real .env files are gitignored. The app runs with NO external keys (AI → mock,
# STT → mock), so local dev works out of the box; production needs the values
# marked REQUIRED below.

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                       # development | staging | production
PORT=3001                                  # backend Express port
CLIENT_ORIGIN=http://localhost:5173        # REQUIRED in prod: the deployed frontend origin (CORS)
DATABASE_URL=file:./data/stratis.db        # SQLite file path (node:sqlite). Single-instance file DB.

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in prod: set a long random secret. The default below is INSECURE and
# for local dev only — tokens signed with it must never reach production.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# ── AI provider ───────────────────────────────────────────────────────────────
# groq → free hosted Llama (needs GROQ_API_KEY) | ollama → local | mock → offline stub.
# If AI_PROVIDER=groq but GROQ_API_KEY is empty, the app falls back to mock.
AI_PROVIDER=mock
AI_TIMEOUT_MS=10000
GROQ_API_KEY=                              # REQUIRED if AI_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Speech-to-text ────────────────────────────────────────────────────────────
# deepgram → real STT (needs DEEPGRAM_API_KEY) | mock → placeholder transcript.
STT_PROVIDER=mock
STT_TIMEOUT_MS=15000
DEEPGRAM_API_KEY=                          # REQUIRED if STT_PROVIDER=deepgram
DEEPGRAM_MODEL=nova-2

# ── Frontend (Vite, build-time) ───────────────────────────────────────────────
# REQUIRED in prod: where the browser reaches the backend. In local dev these
# default to localhost:3001, so you can leave them unset.
# VITE_WS_BASE is derived from VITE_API_BASE (http→ws / https→wss) if omitted.
VITE_API_BASE=http://localhost:3001
# VITE_WS_BASE=wss://api.your-domain.com
