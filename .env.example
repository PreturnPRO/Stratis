# ─────────────────────────────────────────────────────────────────────────────
# Stratis — environment template
# Copy to .env (dev), .env.staging, or .env.production and fill in values.
# NO real values are ever committed to Git (.env* is gitignored).
# The app RUNS WITHOUT any keys — AI falls back to a deterministic mock,
# and voice falls back to the browser Web Speech API.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001                       # backend (Express + WebSocket)
CLIENT_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Default: local SQLite file, auto-created at backend/../data/stratis.db
DATABASE_URL=file:./data/stratis.db

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ── AI provider (S1-T03-B) ───────────────────────────────────────────────────
# AI_PROVIDER = groq | ollama | mock
#   groq   → free hosted Llama 3.3 70B. Get a free key at console.groq.com.
#   ollama → fully local + fine-tunable open model (install + run Ollama; no key).
#   mock   → deterministic offline stub, no network. Used automatically if
#            provider=groq but GROQ_API_KEY is empty, so the app always responds.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

AI_TIMEOUT_MS=10000

# NOTE: speech-to-text keys (DEEPGRAM) are added in S1-T04.
# ── Speech-to-text — S1-T04-A ────────────────────────────────────────────────
STT_PROVIDER=mock
STT_TIMEOUT_MS=15000
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2