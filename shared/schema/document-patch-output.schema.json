{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stratis Document Patch Output",
  "type": "object",
  "required": ["output_type", "session_id", "project_id", "base_document_version", "overall_change_summary", "patches"],
  "properties": {
    "output_type": { "const": "document_patch_output" },
    "session_id": { "type": "string" },
    "project_id": { "type": "string" },
    "base_document_version": { "type": "integer", "minimum": 0 },
    "overall_change_summary": { "type": "string" },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["client_patch_id", "operation", "section_key", "section_title", "new_content", "reason", "confidence", "evidence"],
        "properties": {
          "client_patch_id": { "type": "string" },
          "operation": {
            "type": "string",
            "enum": ["replace_section", "append_to_section", "insert_section"]
          },
          "section_key": { "type": "string" },
          "section_title": { "type": "string" },
          "new_content": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/definitions/evidence" }
          },
          "related_live_card_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "definitions": {
    "evidence": {
      "type": "object",
      "required": ["transcript_ref", "timestamp_start", "timestamp_end", "speaker", "quote"],
      "properties": {
        "transcript_ref": { "type": "string" },
        "timestamp_start": { "type": "string" },
        "timestamp_end": { "type": "string" },
        "speaker": { "type": "string" },
        "quote": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}