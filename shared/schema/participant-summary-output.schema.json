{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stratis Participant Summary Output",
  "type": "object",
  "required": ["output_type", "session_id", "summary_title", "summary_subtitle", "participants", "duration_minutes", "summary_blocks", "action_items"],
  "properties": {
    "output_type": { "const": "participant_summary_output" },
    "session_id": { "type": "string" },
    "summary_title": { "type": "string" },
    "summary_subtitle": { "type": "string" },
    "participants": {
      "type": "array",
      "items": { "type": "string" }
    },
    "duration_minutes": {
      "type": "number",
      "minimum": 0
    },
    "summary_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_type", "title", "content", "visible_to_participants"],
        "properties": {
          "block_type": {
            "type": "string",
            "enum": ["OVERVIEW", "WHAT_CHANGED", "DECISIONS", "OPEN_ITEMS", "ASSUMPTIONS", "RISKS", "ACTION_ITEMS", "NEXT_STEPS"]
          },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "visible_to_participants": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task", "owner", "due_date"],
        "properties": {
          "task": { "type": "string" },
          "owner": { "type": "string" },
          "due_date": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}