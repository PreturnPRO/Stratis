{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stratis Tree Node Output",
  "type": "object",
  "required": ["output_type", "session_id", "project_id", "source_document_version", "meeting_node", "child_nodes"],
  "properties": {
    "output_type": { "const": "tree_node_output" },
    "session_id": { "type": "string" },
    "project_id": { "type": "string" },
    "source_document_version": { "type": "integer", "minimum": 0 },
    "source_document_patch_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "meeting_node": { "$ref": "#/definitions/node" },
    "child_nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/node" }
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["client_node_id", "node_type", "node_category", "user_title", "brief_detail", "status", "source_authority", "affects_pm_document", "confidence", "evidence"],
      "properties": {
        "client_node_id": { "type": "string" },
        "node_type": {
          "type": "string",
          "enum": ["MEETING", "DECISION", "ASSUMPTION", "RISK", "OPEN_QUESTION", "SUMMARY"]
        },
        "node_category": {
          "type": "string",
          "enum": ["CONTAINER", "ITEM"]
        },
        "user_title": { "type": "string" },
        "ai_subtitle": { "type": "string" },
        "brief_detail": { "type": "string" },
        "impact_level": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        },
        "document_change": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["VALIDATED", "UNVALIDATED", "STALLED", "BLOCKED", "ARCHIVED"]
        },
        "path_state": {
          "type": "string",
          "enum": ["CHOSEN_PATH", "ALTERNATIVE", "SUPERSEDED", "ARCHIVED"]
        },
        "activity_state": {
          "type": "string",
          "enum": ["ACTIVE", "INACTIVE"]
        },
        "is_current": { "type": "boolean" },
        "is_latest": { "type": "boolean" },
        "source_authority": {
          "type": "string",
          "enum": ["PM_DOCUMENT_APPROVED", "FACILITATOR_APPROVED", "TEMPORARY_AI_NODE", "TRANSCRIPT_DERIVED"]
        },
        "affects_pm_document": { "type": "boolean" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/definitions/evidence" }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["transcript_ref", "timestamp_start", "timestamp_end", "speaker", "quote"],
      "properties": {
        "transcript_ref": { "type": "string" },
        "timestamp_start": { "type": "string" },
        "timestamp_end": { "type": "string" },
        "speaker": { "type": "string" },
        "quote": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}