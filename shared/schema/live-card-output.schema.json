{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stratis Live Card Output",
  "type": "object",
  "required": ["output_type", "session_id", "chunk_id", "chunk_signal", "rolling_memory_update", "cards"],
  "properties": {
    "output_type": { "const": "live_card_output" },
    "session_id": { "type": "string" },
    "chunk_id": { "type": "string" },
    "chunk_signal": {
      "type": "string",
      "enum": ["IMPORTANT", "LOW_SIGNAL", "IGNORE"]
    },
    "rolling_memory_update": { "type": "string" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["client_card_id", "card_type", "title", "brief_description", "urgency", "confidence", "evidence", "suggested_state"],
        "properties": {
          "client_card_id": { "type": "string" },
          "card_type": {
            "type": "string",
            "enum": ["QUESTION_SUGGESTION", "AGENDA_DRIFT", "RISK", "DECISION_NEEDED", "ASSUMPTION"]
          },
          "title": { "type": "string" },
          "brief_description": { "type": "string" },
          "suggested_question": { "type": "string" },
          "urgency": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH"]
          },
          "related_agenda_item": { "type": "string" },
          "reason_now": { "type": "string" },
          "expected_resolution_signal": { "type": "string" },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/definitions/evidence" }
          },
          "suggested_state": {
            "type": "string",
            "enum": ["NEW", "ACTIVE", "ANSWERED", "DISMISSED"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "definitions": {
    "evidence": {
      "type": "object",
      "required": ["transcript_ref", "timestamp_start", "timestamp_end", "speaker", "quote"],
      "properties": {
        "transcript_ref": { "type": "string" },
        "timestamp_start": { "type": "string" },
        "timestamp_end": { "type": "string" },
        "speaker": { "type": "string" },
        "quote": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}